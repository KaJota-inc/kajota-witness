# 0G Galileo testnet (chain ID 16602)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# Wallet with testnet 0G tokens — get from https://faucet.0g.ai (0.1 0G/day)
WITNESS_DEPLOYER_PK=0xYOUR_TESTNET_PRIVATE_KEY_HERE

# Groq API key for the jury LLMs — free tier at https://console.groq.com/keys (gsk_...)
GROQ_API_KEY=gsk_...

# Server
PORT=4022

# OPTIONAL: on-chain verdict anchor on 0G Galileo
# Set after running: npx tsx scripts/deploy-anchor.ts
WITNESS_ANCHOR_ADDRESS=

# Arc Testnet (USDC-as-gas) — for BondedWitnessAnchor deploy
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_USDC=0x3600000000000000000000000000000000000000
# ARC_TREASURY defaults to deployer address if unset — override for a
# separate community treasury wallet:
# ARC_TREASURY=0x...
