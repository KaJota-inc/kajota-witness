# The 0G Storage TypeScript SDK pins `ethers@6.13.1` exactly as a
# peer dep. We use ethers@6.17.x at runtime (verified compatible —
# we only touch JsonRpcProvider, Wallet, ContractFactory, keccak256,
# toUtf8Bytes — all stable across 6.x). npm's strict peer resolution
# rejects this; --legacy-peer-deps gets us back to npm-7-era behavior
# (warn but install). Applies to all installs in this project —
# Render, fresh clones, CI, local dev.
legacy-peer-deps=true
